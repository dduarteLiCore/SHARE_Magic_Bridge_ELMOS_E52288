#!/bin/bash
# MagicBridge - Cargar datos HMF
# Uso: magicbridge-load <archivo.hmf> <puerto> <PCB> <variante> [opciones]
#
# Ejemplo:
#   ./magicbridge-load datos.hmf /dev/ttyACM0 5 D
#   ./magicbridge-load datos.hmf /dev/ttyACM0 5 D --json result.json --quiet

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
python3 "$SCRIPT_DIR/runner_load.py" "$@"
