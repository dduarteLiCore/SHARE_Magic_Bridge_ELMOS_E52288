#!/bin/bash
# MagicBridge - Ejecutar comando
# Uso: magicbridge-cmd <puerto> <comando> [opciones]
#
# Comandos disponibles:
#   W<PCB><var>  Escribir chip  (ej: W5d)
#   R<PCB><var>  Leer chip      (ej: R5d)
#   P<PCB><var>  Programar chip (ej: P5d)
#
# Ejemplo:
#   ./magicbridge-cmd /dev/ttyACM0 W5d
#   ./magicbridge-cmd /dev/ttyACM0 R5d --json result.json

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
python3 "$SCRIPT_DIR/runner_cmd.py" "$@"
